# ── SERVER ──────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# Frontend URL (your Vercel URL)
FRONTEND_URL=https://mo-miami.vercel.app

# ── SECURITY ──────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_RANDOM_64_CHARS

# ── DATABASE (Railway PostgreSQL) ─────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/railway

# ── STRIPE ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_XXXXXXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXX

# Stripe Price IDs — create in Stripe dashboard
STRIPE_PRICE_REPORT=price_XXXXXXXXXXXXXXXXXXXX
STRIPE_PRICE_MONTHLY=price_XXXXXXXXXXXXXXXXXXXX
STRIPE_PRICE_ANNUAL=price_XXXXXXXXXXXXXXXXXXXX

# ── MIAMI-DADE CLERK OFFICIAL RECORDS ────────────────────────────────────────
# Register at onlineservices.miamidadeclerk.gov — buy search units at $1 each
CLERK_ACCOUNT_EMAIL=your@email.com
CLERK_ACCOUNT_PASSWORD=ENCRYPTED_DO_NOT_PUT_PLAINTEXT_HERE
# Store a pre-purchased session token if Clerk supports it

# ── MLS / iMapp (AUTHORIZED CREDENTIALS ONLY) ─────────────────────────────────
# These MUST be stored here, NEVER in the frontend
MLS_USERNAME=your_mls_username
MLS_PASSWORD=ENCRYPTED
MLS_ENDPOINT=https://your-mls-rets-endpoint.com

IMAPP_USERNAME=your_imapp_username
IMAPP_PASSWORD=ENCRYPTED

# ── SKIP TRACE ────────────────────────────────────────────────────────────────
BATCH_SKIP_API_KEY=your_batchskiptrace_key

# ── EMAIL (Resend — 3000 free/mo) ─────────────────────────────────────────────
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXX

# ── MAPS (optional) ───────────────────────────────────────────────────────────
GOOGLE_MAPS_KEY=your_key_here
MAPBOX_TOKEN=your_token_here
